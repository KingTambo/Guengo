# Guengo — copy to `.env` at the repo root and fill in your key.
# Never commit `.env` (it is gitignored).

# Gemini 2.5 Flash Native Audio (Live API)
GEMINI_API_KEY=
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# Subtitle cleanup + EN→FR (generateContent — default gemini-2.5-flash; avoid deprecated gemini-2.0-flash for new API keys)
# GEMINI_CAPTION_MODEL=gemini-2.5-flash

# Optional — connexion Google (OAuth) sur /login et /signup via Supabase
# Créer un projet sur https://supabase.com, activer le provider Google, et ajouter
# l’URL de redirection : http://127.0.0.1:8080/app (prod : votre origine + /app)
#
# Vercel (static) : ajoutez SUPABASE_URL et SUPABASE_ANON_KEY dans Project → Settings → Environment Variables
# (disponibles au build — la clé anon est publique). Railway : mêmes noms sur le service + redeploy.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Server
# GUENGO_PUBLIC_DIR=../frontend/public
# PORT=8080
# RUST_LOG=info

# ── Production (Railway) ──
# Live app: https://guengo-frontend.up.railway.app
#
# Railway setup (required — fixes "npm could not be found"):
# • Service → Settings → Root Directory = "/"  (NOT "frontend")
# • Remove any custom Start Command in the dashboard (npm run …)
# • Builder should be Dockerfile (see railway.toml in repo root)
#
# Variables (same as local). Railway sets PORT automatically.
# PUBLIC_APP_URL=https://guengo-frontend.up.railway.app
# Supabase Auth → Redirect URLs: https://guengo-frontend.up.railway.app/app
# Stripe webhook (if used): https://guengo-frontend.up.railway.app/api/stripe/webhook

# ── Stripe (accès après onboarding) — ajoutez seulement la valeur après = dans `.env`.

# Url publique de l’application pour les redirections Checkout (doit être l’origine réelle).
# Prod Railway: https://guengo-frontend.up.railway.app

PUBLIC_APP_URL=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# JWT service_role depuis le dashboard Supabase — uniquement côté backend (API Rust),
# pour marquer `profiles.is_premium` après les webhooks Stripe. Ne pas mettre dans le SPA.

SUPABASE_SERVICE_ROLE_KEY=

# Webhooks Stripe (production) : HTTPS vers https://<votre-domaine>/api/stripe/webhook avec
# checkout.session.completed, customer.subscription.updated, customer.subscription.deleted.
# Dev : `stripe listen --forward-to http://127.0.0.1:8080/api/stripe/webhook` et collez le whsec_* dans STRIPE_WEBHOOK_SECRET.

